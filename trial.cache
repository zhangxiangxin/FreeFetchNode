ul>\n </div>\n </div>\n </div>\n </main>\n\n <footer>\n <span data-i18n="foot_before"></span><a href="https://bsncdn.ai" target="_blank" rel="noopener">bsncdn</a><span data-i18n="foot_after"></span>\n </footer>\n\n <script>\n (function(){\n var i18n={\n zh:{\n docTitle:"回源请求超时",\n pill:"504 · 网关超时",\n title:"回源请求超时",\n lede:"边缘节点回源时等待源站响应超时，未能取得有效响应。",\n k_client:"客户端 IP", k_node:"节点 IP", k_status:"状态",\n status_text:"网关超时",\n h_what:"发生了什么", p_what:"CDN 节点请求源服务器时等待过久，源站未在限定时间内响应。",\n h_do:"如何解决",\n role_user:"访客", p_user:"通常为临时问题，请稍候重试；若持续出现，请联系网站管理员。",\n role_admin:"管理员", p_admin:"请检查 bsncdn 回源节点与源站之间的链路是否畅通，以及源站防火墙是否拉黑了回源节点。",\n foot_before:"由 ", foot_after:" 提供的性能和安全保障"\n },\n en:{\n docTitle:"Gateway Timeout",\n pill:"504 · Gateway Timeout",\n title:"The origin server timed out",\n lede:"The edge node timed out while waiting for the origin to respond.",\n k_client:"Client IP", k_node:"Node IP", k_status:"Status",\n status_text:"Gateway Timeout",\n h_what:"What happened", p_what:"The CDN node waited too long while requesting the origin server, and the origin did not respond within the time limit.",\n h_do:"What to do",\n role_user:"Visitor", p_user:"This is usually temporary — wait a moment and try again. If it persists, contact the site administrator.",\n role_admin:"Administrator", p_admin:"Check that the link between bsncdn\'s edge nodes and the origin is healthy, and whether the origin firewall is blocking the edge nodes.",\n foot_before:"Performance and security provided by ", foot_after:""\n }\n };\n function detect(){\n var l=(navigator.language||navigator.userLanguage||"en").toLowerCase();\n return l.indexOf("zh")===0?"zh":"en";\n }\n var d=i18n[detect()]||i18n.en;\n document.documentElement.lang=(d===i18n.zh?"zh-CN":"en");\n document.title=d.docTitle;\n var nodes=document.querySelectorAll("[data-i18n]");\n for(var i=0;i<nodes.length;i++){\n var key=nodes[i].getAttribute("data-i18n");\n if(d[key]!=null){ nodes[i].textContent=d[key]; }\n }\n })();\n </script>\n</body>\n</html>'

